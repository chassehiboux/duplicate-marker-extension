{
  "manifest_version": 3,
  "name": "Проверка ИНН и Смерти (Pyramid)",
  "version": "2.4",
  "permissions": [
    "scripting",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "*://service.nalog.ru/*",
    "*://*.pyramid.vostok-electra.ru/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "inn_death_background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["inn_death_content.js"],
      "run_at": "document_end",
      "all_frames": true
    }
  ]
}